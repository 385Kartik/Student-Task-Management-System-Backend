{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs", // <--- Wapasi CommonJS pe, ye sabse safe hai
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,      // <--- Isko false kar de, build turant pass hoga
    "noImplicitAny": false, // <--- Ye saare 'parameter s has any type' error khatam kar dega
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}